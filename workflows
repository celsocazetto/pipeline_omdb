name: Validate source branch

on:
  pull_request:
    branches:
      - main

jobs:
  validate:
    runs-on: ubuntu-latest

    steps:
      - name: Validate source branch
        run: |
          if [ "${{ github.head_ref }}" != "stage" ]; then
            echo "Somente PRs vindos da branch stage são permitidos."
            exit 1
          fi
